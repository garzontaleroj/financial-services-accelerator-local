# ─────────────────────────────────────────────────────────────────────────────
# WSO2 Financial Services Accelerator – Environment Variables
# Copy this file to .env and fill in the values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# ── Accelerator version ────────────────────────────────────────────────────
ACCELERATOR_VERSION=4.1.2-SNAPSHOT

# ── WSO2 product versions ──────────────────────────────────────────────────
WSO2_APIM_VERSION=4.3.0
WSO2_IS_VERSION=7.1.0

# ── Database – MySQL ───────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_TYPE=mysql
DB_DRIVER=com.mysql.cj.jdbc.Driver

# API Manager databases
DB_APIMGT=apimgtdb
DB_AM_CONFIG=am_configdb
DB_USER_STORE=userdb

# IS / Consent databases
DB_FS_CONSENT=fs_consentdb
DB_FS_EVENTS=fs_eventsdb

# Shared credentials  ⚠️  Change these before deploying to any environment
DB_USER=wso2user
DB_PASS=wso2password

# ── WSO2 admin credentials ─────────────────────────────────────────────────
WSO2_ADMIN_USER=admin
WSO2_ADMIN_PASS=admin

# ── Hostnames (used in inter-service communication) ────────────────────────
IS_HOST=fs-is
APIM_HOST=fs-apim

# ── Self-Care Portal (nginx) ───────────────────────────────────────────────
PORTAL_PORT=3000

# ── Demo Backend ───────────────────────────────────────────────────────────
DEMO_BACKEND_PORT=9090
